{
  "display_information": {
    "name": "Kapibala Slack Agent",
    "description": "Kapibala Slack Agent",
    "background_color": "#bf6626"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Kapibala Slack Agent",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "New Claim",
        "type": "global",
        "callback_id": "expense_claim",
        "description": "Creates New Expense Claim"
      },
      {
        "name": "New Feedback",
        "type": "global",
        "callback_id": "new_feedback",
        "description": "Creates New Feedback"
      },
      {
        "name": "New Candidate",
        "type": "global",
        "callback_id": "new_candidate",
        "description": "Creates New Candidate"
      }
    ],
    "assistant_view": {
      "assistant_description": "Slack agent description"
    }
  },
  "oauth_config": {
    "scopes": {
      "user": [
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "channels:history",
        "groups:history",
        "mpim:history",
        "im:history",
        "canvases:read",
        "canvases:write",
        "users:read",
        "users:read.email"
      ],
      "user_optional": [
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "chat:write",
        "groups:history",
        "mpim:history",
        "im:history",
        "canvases:read",
        "canvases:write"
      ],
      "bot": [
        "files:write",
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "files:read",
        "groups:history",
        "im:history",
        "mpim:history",
        "reactions:write",
        "users:read",
        "users:read.email",
        "commands"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://kapibala-slack-agent.vercel.app/api/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://kapibala-slack-agent.vercel.app/api/slack/events"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
